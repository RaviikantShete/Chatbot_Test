{
  "name": "paywatch-chatbot-tests",
  "version": "1.0.0",
  "scripts": {
    "test": "node node_modules/@cucumber/cucumber/bin/cucumber-js --require support/world.js --require support/hooks.js --require \"features/step_definitions/**/*.js\" features/**/*.feature",
    "test:headed": "set HEADED=true && node node_modules/@cucumber/cucumber/bin/cucumber-js --require support/world.js --require support/hooks.js --require \"features/step_definitions/**/*.js\" features/**/*.feature",
    "test:smoke": "node node_modules/@cucumber/cucumber/bin/cucumber-js --require support/world.js --require support/hooks.js --require \"features/step_definitions/**/*.js\" --tags @smoke features/**/*.feature",
    "test:regression": "node node_modules/@cucumber/cucumber/bin/cucumber-js --require support/world.js --require support/hooks.js --require \"features/step_definitions/**/*.js\" --tags @regression features/**/*.feature",
    "test:ui": "node node_modules/@cucumber/cucumber/bin/cucumber-js --require support/world.js --require support/hooks.js --require \"features/step_definitions/**/*.js\" --tags @ui features/**/*.feature",
    "test:functional": "node node_modules/@cucumber/cucumber/bin/cucumber-js --require support/world.js --require support/hooks.js --require \"features/step_definitions/**/*.js\" --tags @functional features/**/*.feature",
    "test:accessibility": "node node_modules/@cucumber/cucumber/bin/cucumber-js --require support/world.js --require support/hooks.js --require \"features/step_definitions/**/*.js\" --tags @accessibility features/**/*.feature",
    "test:performance": "node node_modules/@cucumber/cucumber/bin/cucumber-js --require support/world.js --require support/hooks.js --require \"features/step_definitions/**/*.js\" --tags @performance features/**/*.feature",
    "test:report": "node node_modules/@cucumber/cucumber/bin/cucumber-js --require support/world.js --require support/hooks.js --require \"features/step_definitions/**/*.js\" --format json:reports/cucumber-report.json features/**/*.feature && node support/customReport.js"
  },
  "dependencies": {
    "@cucumber/cucumber": "^10.3.1",
    "@playwright/test": "^1.43.0",
    "playwright": "^1.43.0",
    "axe-playwright": "^2.0.1",
    "@axe-core/playwright": "^4.8.5",
    "chai": "^4.4.1",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.2.0",
    "uuid": "^9.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  }
}
